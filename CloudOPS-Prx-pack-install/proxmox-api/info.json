{
  "name": "proxmox-api",
  "version": "2.0.4",
  "label": "API Connector Proxmox",
  "description": "Native FortiSOAR connector for the Proxmox VE API. Enables VM and container provisioning, configuration and deletion via the Proxmox REST API using token-based authentication. Supports arbitrary configurations per connector instance (host, port, token).",
  "publisher": "Fortinet / Custom",
  "cs_approved": false,
  "cs_compatible": true,
  "category": "Infrastructure",
  "help_online": "https://pve.proxmox.com/pve-docs/api-viewer/",
  "configuration": {
    "fields": [
      {
        "name": "host",
        "title": "Hostname / IP",
        "type": "text",
        "editable": true,
        "visible": true,
        "required": true,
        "placeholder": "192.168.1.100",
        "tooltip": "IP address or hostname of the Proxmox VE server",
        "description": "Hostname or IP address of the Proxmox VE server."
      },
      {
        "name": "port",
        "title": "Port",
        "type": "integer",
        "editable": true,
        "visible": true,
        "required": false,
        "value": 8006,
        "placeholder": "8006",
        "description": "Proxmox API port (default: 8006)."
      },
      {
        "name": "node",
        "title": "Default Node Name",
        "type": "text",
        "editable": true,
        "visible": true,
        "required": false,
        "placeholder": "pve",
        "tooltip": "Default node name (for example pve). Used when no node parameter is provided in the playbook.",
        "description": "Optional default node name for all operations (for example pve)."
      },
      {
        "name": "verify_ssl",
        "title": "Verify SSL",
        "type": "checkbox",
        "editable": true,
        "visible": true,
        "required": false,
        "value": false,
        "description": "Verify the server SSL certificate (default: false for testing)."
      },
      {
        "name": "api_token",
        "title": "API Token",
        "type": "password",
        "editable": true,
        "visible": true,
        "required": true,
        "placeholder": "user@pve!tokenid=secret-uuid",
        "tooltip": "PVEAPIToken in the format user@realm!tokenid=secret",
        "description": "Proxmox API token (PVEAPIToken). Format: user@realm!tokenid=secret"
      }
    ]
  },
  "operations": [
    {
      "operation": "get_version",
      "title": "Get Version",
      "description": "Returns the Proxmox VE version",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [],
      "output_schema": {"version": "", "release": "", "repoid": ""}
    },
    {
      "operation": "get_next_vmid",
      "title": "Get Next VMID",
      "description": "Returns the next available VMID",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [],
      "output_schema": {"data": ""}
    },
    {
      "operation": "clone_vm",
      "title": "Clone VM",
      "description": "Clones a VM from a template",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": true, "description": "Proxmox node name (for example pve)"},
        {"name": "vmid", "title": "Template VMID", "type": "integer", "required": true, "description": "VMID of the template"},
        {"name": "newid", "title": "New VMID", "type": "integer", "required": true, "description": "VMID of the new VM"},
        {"name": "name", "title": "Name", "type": "text", "required": true, "description": "Name of the new VM"},
        {"name": "storage", "title": "Storage", "type": "text", "required": false, "description": "Storage for the VM disk"},
        {"name": "full", "title": "Full Clone", "type": "checkbox", "required": false, "value": true, "description": "Full clone (1) or linked clone (0)"}
      ],
      "output_schema": {"upid": "", "data": null}
    },
    {
      "operation": "create_container",
      "title": "Create Container",
      "description": "Creates an LXC container",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": true, "description": "Proxmox node name"},
        {"name": "vmid", "title": "VMID", "type": "integer", "required": true, "description": "Container VMID"},
        {"name": "hostname", "title": "Hostname", "type": "text", "required": true, "description": "Hostname of the container"},
        {"name": "ostemplate", "title": "OS Template", "type": "text", "required": true, "description": "Template (for example local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst)"},
        {"name": "cores", "title": "Cores", "type": "integer", "required": false, "value": 2, "description": "Number of CPU cores"},
        {"name": "memory", "title": "Memory (MB)", "type": "integer", "required": false, "value": 2048, "description": "RAM in MB"},
        {"name": "rootfs", "title": "Root FS", "type": "text", "required": true, "description": "for example local-lvm:20"},
        {"name": "net0", "title": "Network", "type": "text", "required": true, "description": "net0 configuration (name=eth0,bridge=vmbr0,ip=.../24,gw=...)"},
        {"name": "password", "title": "Root Password", "type": "password", "required": false, "description": "Root password"},
        {"name": "swap", "title": "Swap (MB)", "type": "integer", "required": false, "value": 0, "description": "Swap in MB"},
        {"name": "nameserver", "title": "Nameserver", "type": "text", "required": false, "description": "DNS (for example 1.1.1.1)"},
        {"name": "unprivileged", "title": "Unprivileged", "type": "checkbox", "required": false, "value": true, "description": "Create unprivileged container (0=privileged, 1=unprivileged). Default true (unprivileged + nesting=1)."},
        {"name": "features", "title": "Features", "type": "text", "required": false, "description": "LXC features (e.g. nesting=1). Use nesting=1 for console/nesting support."}
      ],
      "output_schema": {"upid": "", "data": null}
    },
    {
      "operation": "config_container",
      "title": "Configure Container",
      "description": "Updates LXC container config (e.g. features=nesting=1, unprivileged). Use after create if create API ignored these.",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": true, "description": "Proxmox node name"},
        {"name": "vmid", "title": "VMID", "type": "integer", "required": true, "description": "Container VMID"},
        {"name": "body_params", "title": "Body Parameters", "type": "json", "required": true, "description": "Config as JSON (e.g. {\"features\": \"nesting=1\", \"unprivileged\": 0})"}
      ],
      "output_schema": {}
    },
    {
      "operation": "config_vm",
      "title": "Configure VM",
      "description": "Configures a VM (for example cloud-init, networking)",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": true, "description": "Proxmox node name"},
        {"name": "vmid", "title": "VMID", "type": "integer", "required": true, "description": "VMID of the VM"},
        {"name": "body_params", "title": "Body Parameters", "type": "json", "required": true, "description": "Parameters as JSON object (for example ipconfig0, nameserver, ciuser)"}
      ],
      "output_schema": {}
    },
    {
      "operation": "start_vm",
      "title": "Start VM",
      "description": "Starts a VM",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": true, "description": "Proxmox node name"},
        {"name": "vmid", "title": "VMID", "type": "integer", "required": true, "description": "VMID of the VM"}
      ],
      "output_schema": {"upid": "", "data": null}
    },
    {
      "operation": "stop_vm",
      "title": "Stop VM",
      "description": "Stops a VM",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": true, "description": "Proxmox node name"},
        {"name": "vmid", "title": "VMID", "type": "integer", "required": true, "description": "VMID of the VM"}
      ],
      "output_schema": {"upid": "", "data": null}
    },
    {
      "operation": "start_container",
      "title": "Start Container",
      "description": "Starts an LXC container",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": true, "description": "Proxmox node name"},
        {"name": "vmid", "title": "VMID", "type": "integer", "required": true, "description": "VMID of the container"}
      ],
      "output_schema": {"upid": "", "data": null}
    },
    {
      "operation": "stop_container",
      "title": "Stop Container",
      "description": "Stops an LXC container",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": true, "description": "Proxmox node name"},
        {"name": "vmid", "title": "VMID", "type": "integer", "required": true, "description": "VMID of the container"}
      ],
      "output_schema": {"upid": "", "data": null}
    },
    {
      "operation": "destroy_vm",
      "title": "Destroy VM",
      "description": "Deletes a VM (optional purge=1)",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": true, "description": "Proxmox node name"},
        {"name": "vmid", "title": "VMID", "type": "integer", "required": true, "description": "VMID of the VM"},
        {"name": "purge", "title": "Purge", "type": "checkbox", "required": false, "value": true, "description": "Also delete unused volumes"}
      ],
      "output_schema": {"data": null}
    },
    {
      "operation": "destroy_container",
      "title": "Destroy Container",
      "description": "Deletes an LXC container",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": true, "description": "Proxmox node name"},
        {"name": "vmid", "title": "VMID", "type": "integer", "required": true, "description": "VMID of the container"},
        {"name": "force", "title": "Force", "type": "checkbox", "required": false, "value": false, "description": "Force stop running container before destroying (force=1)"}
      ],
      "output_schema": {"data": null}
    },
    {
      "operation": "list_vms",
      "title": "List VMs",
      "description": "Lists all VMs on the node (GET /nodes/{node}/qemu). Optionally include config (disks, net) per VM.",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": false, "description": "Proxmox node name (optional, uses connector default if empty)"},
        {"name": "include_config", "title": "Include config", "type": "boolean", "required": false, "description": "If true, fetch config (disks, network) for each VM (more API calls)"}
      ],
      "output_schema": {"data": [{"vmid": null, "name": null, "node": null, "status": null, "config": {}, "disksSummary": null, "interfacesSummary": null}]}
    },
    {
      "operation": "list_containers",
      "title": "List Containers",
      "description": "Lists all LXC containers on the node (GET /nodes/{node}/lxc). Optionally include config (rootfs, mp, net) per container.",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": false, "description": "Proxmox node name (optional, uses connector default if empty)"},
        {"name": "include_config", "title": "Include config", "type": "boolean", "required": false, "description": "If true, fetch config (disks, network) for each container (more API calls)"}
      ],
      "output_schema": {"data": [{"vmid": null, "name": null, "node": null, "status": null, "config": {}, "disksSummary": null, "interfacesSummary": null}]}
    },
    {
      "operation": "get_vm_config",
      "title": "Get VM Config",
      "description": "VM config (disks, network interfaces). For use in inventory sync.",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": false, "description": "Proxmox node name (optional, uses connector default if empty)"},
        {"name": "vmid", "title": "VMID", "type": "number", "required": true, "description": "VMID of the VM"}
      ],
      "output_schema": {}
    },
    {
      "operation": "get_container_config",
      "title": "Get Container Config",
      "description": "Container config (rootfs, mp, network interfaces). For use in inventory sync.",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": false, "description": "Proxmox node name (optional, uses connector default if empty)"},
        {"name": "vmid", "title": "VMID", "type": "number", "required": true, "description": "VMID of the container"}
      ],
      "output_schema": {}
    },
    {
      "operation": "get_task_status",
      "title": "Get Task Status",
      "description": "Status of an asynchronous task (for example clone job, UPID from response)",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": false, "description": "Proxmox node name (optional, uses connector default if empty)"},
        {"name": "upid", "title": "UPID", "type": "text", "required": true, "description": "Task UPID (for example UPID:pve:00001234:...)", "placeholder": "UPID:pve:00001234:5678:90ABCDEF:qmclone:2000:root@pam:"}
      ],
      "output_schema": {}
    },
    {
      "operation": "get_nodes",
      "title": "Get Nodes",
      "description": "List of all cluster nodes and their status (online/offline)",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [],
      "output_schema": {"data": []}
    },
    {
      "operation": "get_cluster_resources",
      "title": "Get Cluster Resources",
      "description": "Cluster resources (optionally filter by type=node|vm|storage)",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "type", "title": "Type Filter", "type": "text", "required": false, "placeholder": "node", "description": "Optional: node, vm, storage"}
      ],
      "output_schema": {"data": []}
    },
    {
      "operation": "get_vm_status",
      "title": "Get VM Status",
      "description": "Detailed status of a VM (running/stopped). Requires VM.Audit on the VM",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": false, "description": "Proxmox node name (optional, uses connector default if empty)"},
        {"name": "vmid", "title": "VMID", "type": "integer", "required": true, "description": "VMID of the VM"}
      ],
      "output_schema": {}
    },
    {
      "operation": "get_container_status",
      "title": "Get Container Status",
      "description": "Detailed status of a container (running/stopped). Requires VM.Audit",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": false, "description": "Proxmox node name (optional, uses connector default if empty)"},
        {"name": "vmid", "title": "VMID", "type": "integer", "required": true, "description": "VMID of the container"}
      ],
      "output_schema": {}
    },
    {
      "operation": "get_node_status",
      "title": "Get Node Status",
      "description": "Node resources (memory, CPU). Requires Sys.Audit",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": false, "description": "Proxmox node name (optional, uses connector default if empty)"}
      ],
      "output_schema": {}
    },
    {
      "operation": "get_storage_status",
      "title": "Get Storage Status",
      "description": "Storage status (disk total/free/used). Requires Datastore.Audit",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": false, "description": "Proxmox node name (optional, uses connector default if empty)"},
        {"name": "storage", "title": "Storage", "type": "text", "required": true, "description": "Storage ID (for example local-lvm)"}
      ],
      "output_schema": {}
    },
    {
      "operation": "get_storage_content",
      "title": "Get Storage Content",
      "description": "Storage content (templates, images). Requires Datastore.Audit",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "node", "title": "Node", "type": "text", "required": false, "description": "Proxmox node name (optional, uses connector default if empty)"},
        {"name": "storage", "title": "Storage", "type": "text", "required": true, "description": "Storage ID (for example local)"},
        {"name": "content", "title": "Content Filter", "type": "text", "required": false, "placeholder": "vztmpl,iso", "description": "Optional: vztmpl, iso, images (comma-separated)"}
      ],
      "output_schema": {"data": []}
    },
    {
      "operation": "api_request",
      "title": "API Request (Generic)",
      "description": "Generic API request (GET/POST/PUT/DELETE) for arbitrary endpoints",
      "category": "investigation",
      "is_config_required": true,
      "visible": true,
      "enabled": true,
      "parameters": [
        {"name": "method", "title": "Method", "type": "select", "required": true, "options": ["GET", "POST", "PUT", "DELETE"], "description": "HTTP method"},
        {"name": "url_path", "title": "URL Path", "type": "text", "required": true, "placeholder": "/api2/json/nodes/pve/status", "description": "Path starting after /api2/json/ (without leading slash)"},
        {"name": "body", "title": "Body (form)", "type": "textarea", "required": false, "description": "Body for POST/PUT (application/x-www-form-urlencoded)"},
        {"name": "body_json", "title": "Body (JSON)", "type": "json", "required": false, "description": "Alternative JSON body (if set, body is ignored)"}
      ],
      "output_schema": {}
    }
  ]
}
