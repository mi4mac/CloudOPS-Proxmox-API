              "description": null,
              "arguments": {
                "retention_days": "{{vars.input.params.retentionDays or 30}}",
                "dry_run": "{{vars.input.params.dryRun if vars.input.params.dryRun is not none else true}}",
                "cutoff_ts": "{{arrow.get().shift(days=-(vars.input.params.retentionDays or 30)).int_timestamp}}"
