            },
            {
              "@type": "WorkflowStep",
              "name": "Get Archive Candidates",
              "description": "Policies soft-deleted on firewall older than retention cutoff.",
              "arguments": {
                "query": {
                  "sort": [],
                  "limit": 5000,
                  "logic": "AND",
                  "filters": [
                    {
                      "type": "primitive",
                      "field": "isDeletedOnFirewall",
                      "value": true,
                      "operator": "eq",
                      "_operator": "eq"
                    },
                    {
                      "type": "primitive",
                      "field": "deletedDetectedAt",
                      "value": "{{vars.cutoff_ts}}",
                      "operator": "lte",
                      "_operator": "lte"
                    }
                  ],
                  "__selectFields": [
                    "uuid",
                    "policyID",
                    "name",
                    "fortiGateSerial",
                    "deletedDetectedAt",
                    "policyStatus"
                  ]
                },
                "module": "policies?$limit=5000",
                "checkboxFields": true,
                "step_variables": []
              },
              "status": null,
              "top": "320",
              "left": "40",
              "stepType": "/api/3/workflow_step_types/b593663d-7d13-40ce-a3a3-96dece928770",
              "group": null,
              "uuid": "2b9f0e32-a7a1-4d5c-bc1e-c4d3ce002003"
            },
            {
              "@type": "WorkflowStep",
              "name": "Prepare Archive List",
              "description": "Visible list of policies targeted for archive update.",
              "arguments": {
                "for_each": {
                  "item": "{{vars.steps.Get_Archive_Candidates}}",
                  "parallel": false,
                  "condition": ""
                },
                "archive_uuid": "{{vars.item.uuid}}",
                "archive_policy_id": "{{vars.item.policyID}}",
                "archive_policy_name": "{{vars.item.name}}",
                "archive_forti_serial": "{{vars.item.fortiGateSerial}}",
                "archive_deleted_at": "{{vars.item.deletedDetectedAt}}"
              },
              "status": null,
              "top": "460",
