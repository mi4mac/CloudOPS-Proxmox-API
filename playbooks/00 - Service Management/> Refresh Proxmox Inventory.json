      "arguments": {
        "proxmox_vm_ids": "{{ (vars.steps.List_VMs.data.data or [])|map(attribute='vmid')|map('string')|list + (vars.steps.List_Containers.data.data or [])|map(attribute='vmid')|map('string')|list }}",
