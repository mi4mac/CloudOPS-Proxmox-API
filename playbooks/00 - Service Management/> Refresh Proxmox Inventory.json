    },
    {
      "@type": "WorkflowStep",
      "name": "Compute Orphaned and Not Tracked",
      "description": "Computes orphaned (in FortiSOAR but no longer on Proxmox) and not_tracked (on Proxmox but not in FortiSOAR).",
      "arguments": {
        "proxmox_ids_set": "{{ (vars.proxmox_vm_ids or [])|unique|list }}",
        "records_with_proxmox": "{{ (vars.vm_records or [])|selectattr('proxmoxId')|selectattr('proxmoxId', 'ne', '')|list }}",
        "record_proxmox_ids": "{{ (vars.records_with_proxmox or [])|map(attribute='proxmoxId')|map('string')|list }}",
        "orphaned": "{{ (vars.records_with_proxmox or [])|selectattr('proxmoxId')|rejectattr('proxmoxId', 'in', vars.proxmox_ids_set or [])|list }}",
        "tracked_ids": "{{ (vars.records_with_proxmox or [])|map(attribute='proxmoxId')|map('string')|list }}",
        "not_tracked": "{{ (vars.proxmox_ids_set or [])|reject('in', vars.tracked_ids or [])|list }}"
      },
      "status": null,
      "top": "520",
      "left": "180",
      "stepType": "/api/3/workflow_step_types/04d0cf46-b6a8-42c4-8683-60a7eaa69e8f",
      "group": null,
      "uuid": "11111111-2222-3333-4444-555555555556"
    },
    {
      "@type": "WorkflowStep",
      "name": "Set Sync Report",
      "description": "Creates the final sync report as HTML.",
      "arguments": {
        "sync_report": "<h3>Proxmox Inventory Sync Report</h3><p><strong>Time:</strong> {{ arrow.utcnow().format('YYYY-MM-DD HH:mm') }} UTC</p><p><strong>Proxmox VMs:</strong> {{ (vars.steps.List_VMs.data.data or [])|length }}</p><p><strong>Proxmox containers:</strong> {{ (vars.steps.List_Containers.data.data or [])|length }}</p><p><strong>v_m_instances with proxmoxId:</strong> {{ (vars.records_with_proxmox or [])|length }}</p><h4>Orphaned (in FortiSOAR, no longer on Proxmox):</h4><ul>{% for r in (vars.orphaned or []) %}<li>{{ r.name }} (proxmoxId: {{ r.proxmoxId }})</li>{% else %}<li>None</li>{% endfor %}</ul><h4>Not tracked (on Proxmox, not in FortiSOAR):</h4><ul>{% for vid in (vars.not_tracked or []) %}<li>VMID {{ vid }}</li>{% else %}<li>None</li>{% endfor %}</ul>"
      },
      "status": null,
      "top": "620",
