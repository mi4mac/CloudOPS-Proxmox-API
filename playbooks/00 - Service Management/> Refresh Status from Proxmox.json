                "node": "{{ globalVars.proxmox_default_node | default('pve') }}",
                "vmid": "{{ vars.input.records[0].proxmoxId or '' }}",
                "vm_type": "{{ (vars.input.records[0].vMType.itemValue or '') | lower }}",
