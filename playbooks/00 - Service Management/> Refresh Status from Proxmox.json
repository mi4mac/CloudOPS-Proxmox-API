                "config": "''",
                "params": {
                    "node": "{{ vars.node }}",
                    "vmid": "{{ vars.vmid | int }}"
                },
                "version": "2.0.0",
                "connector": "proxmox-api",
                "operation": "get_vm_status",
                "operationTitle": "Get VM Status",
                "pickFromTenant": false,
                "step_variables": []
            },
            "status": null,
            "top": "330",
            "left": "475",
            "stepType": "/api/3/workflow_step_types/0bfed618-0316-11e7-93ae-92361f002671",
            "group": null,
            "uuid": "f1a2b3c4-d5e6-7890-abcd-700000000007"
        },
        {
            "@type": "WorkflowStep",
            "name": "Set Refresh Result",
            "description": null,
            "arguments": {
                "proxmox_status": "{%- set is_ct = 'ct' in vars.vm_type or vars.vm_type == 'lxc' -%}{%- set s = vars.steps['Get Container Status (API)'] if is_ct else vars.steps['Get VM Status (API)'] -%}{{ s.data.data.status | default('') }}",
                "refresh_ok": "{%- set is_ct = 'ct' in vars.vm_type or vars.vm_type == 'lxc' -%}{%- set s = vars.steps['Get Container Status (API)'] if is_ct else vars.steps['Get VM Status (API)'] -%}{%- if s and not (s.get('Error message') or s.get('error')) -%}true{%- else -%}false{%- endif -%}",
                "status_iri": "",
                "log_msg": "{%- set is_ct = 'ct' in vars.vm_type or vars.vm_type == 'lxc' -%}{%- set s = vars.steps['Get Container Status (API)'] if is_ct else vars.steps['Get VM Status (API)'] -%}{%- if s and not (s.get('Error message') or s.get('error')) -%}<p>Refreshed from Proxmox: {{ s.data.data.status | default('unknown') }}</p>{%- else -%}<p>Refresh failed: {{ (s.get('Error message') or s.get('error') or 'No status response') if s else 'No status step' }}</p>{%- endif -%}"
            },
            "status": null,
            "top": "405",
            "left": "300",
            "stepType": "/api/3/workflow_step_types/04d0cf46-b6a8-42c4-8683-60a7eaa69e8f",
            "group": null,
