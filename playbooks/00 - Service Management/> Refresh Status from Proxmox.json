            "group": null,
            "uuid": "f1a2b3c4-d5e6-7890-abcd-500000000005"
        },
        {
            "@type": "WorkflowStep",
            "name": "Update No Proxmox ID",
            "description": null,
            "arguments": {
                "resource": {
                    "logs": "<p>Refresh Status: No valid Proxmox ID on record. Set Proxmox ID or destroy the record.</p>"
                },
                "operation": "Append",
                "collection": "{{vars.input.records[0]['@id']}}",
                "__recommend": [],
                "collectionType": "/api/3/v_m_instances",
                "fieldOperation": {"recordTags": "Append"},
                "step_variables": []
