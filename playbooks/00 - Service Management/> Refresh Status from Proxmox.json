                "config": "''",
                "params": {
                    "node": "{{ vars.node }}",
                    "vmid": "{{ vars.vmid | int }}"
                },
                "version": "2.0.0",
                "connector": "proxmox-api",
                "operation": "get_container_status",
                "operationTitle": "Get Container Status",
                "pickFromTenant": false,
                "step_variables": []
            },
            "status": null,
            "top": "330",
            "left": "125",
