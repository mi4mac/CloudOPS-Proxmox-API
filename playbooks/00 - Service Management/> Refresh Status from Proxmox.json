                    {
                        "option": "Container",
                        "step_iri": "/api/3/workflow_steps/f1a2b3c4-d5e6-7890-abcd-600000000006",
                        "condition": "{{ 'ct' in vars.vm_type or vars.vm_type == 'lxc' }}",
                        "step_name": "Get Container Status (API)"
                    },
                    {
                        "option": "VM",
                        "default": true,
                        "step_iri": "/api/3/workflow_steps/f1a2b3c4-d5e6-7890-abcd-700000000007",
