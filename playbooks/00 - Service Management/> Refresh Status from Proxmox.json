            "name": "Proxmox ID Valid",
            "description": null,
            "arguments": {
                "conditions": [
                    {
                        "option": "yes",
                        "step_iri": "/api/3/workflow_steps/f1a2b3c4-d5e6-7890-abcd-300000000003",
                        "condition": "{{ vars.has_proxmox_id }}",
                        "step_name": "Route Type"
